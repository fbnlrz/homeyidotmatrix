{
  "id": "com.idotmatrix",
  "version": "0.3.0",
  "compatibility": ">=10.0.0",
  "sdk": 3,
  "platforms": ["local"],
  "name": {
    "en": "iDotMatrix",
    "de": "iDotMatrix",
    "nl": "iDotMatrix"
  },
  "description": {
    "en": "Control iDotMatrix BLE pixel displays from Homey. Show text, clocks, countdowns, scoreboards, images and animated GIFs.",
    "de": "Steuere iDotMatrix BLE-Pixel-Displays mit Homey. Texte, Uhren, Countdowns, Scoreboards, Bilder und animierte GIFs anzeigen.",
    "nl": "Bedien iDotMatrix BLE pixeldisplays vanuit Homey. Toon tekst, klokken, countdowns, scoreborden, afbeeldingen en geanimeerde GIFs."
  },
  "tags": {
    "en": ["ble", "bluetooth", "display", "led", "matrix", "pixel", "idotmatrix"],
    "de": ["ble", "bluetooth", "display", "led", "matrix", "pixel", "idotmatrix"],
    "nl": ["ble", "bluetooth", "display", "led", "matrix", "pixel", "idotmatrix"]
  },
  "category": ["lights"],
  "permissions": ["homey:wireless:ble"],
  "brandColor": "#FF3366",
  "author": {
    "name": "fbnlrz",
    "email": "root@lrnzn.cloud"
  },
  "contributors": {
    "developers": [
      { "name": "fbnlrz", "email": "root@lrnzn.cloud" }
    ]
  },
  "contributing": {
    "donate": {
      "paypal": { "username": "" }
    }
  },
  "source": "https://github.com/fbnlrz/homeyidotmatrix",
  "homepage": "https://github.com/fbnlrz/homeyidotmatrix",
  "bugs": { "url": "https://github.com/fbnlrz/homeyidotmatrix/issues" },
  "support": "https://community.homey.app/t/idotmatrix-app-matrix-devices/155964",
  "homeyCommunityTopicId": 155964,
  "api": {
    "listMedia":     { "method": "GET",    "path": "/media" },
    "uploadMedia":   { "method": "POST",   "path": "/media/:name" },
    "deleteMedia":   { "method": "DELETE", "path": "/media/:name" },
    "diagnostic":    { "method": "GET",    "path": "/diagnostic" }
  },
  "images": {
    "small": "/assets/images/small.png",
    "large": "/assets/images/large.png",
    "xlarge": "/assets/images/xlarge.png"
  },
  "drivers": [
    {
      "id": "idotmatrix",
      "name": {
        "en": "iDotMatrix Display",
        "de": "iDotMatrix Display",
        "nl": "iDotMatrix Display"
      },
      "class": "light",
      "capabilities": ["onoff", "dim"],
      "platforms": ["local"],
      "connectivity": ["ble"],
      "pair": [
        { "id": "list_devices", "template": "list_devices", "navigation": { "next": "add_devices" } },
        { "id": "add_devices", "template": "add_devices" }
      ],
      "images": {
        "small": "/drivers/idotmatrix/assets/images/small.png",
        "large": "/drivers/idotmatrix/assets/images/large.png",
        "xlarge": "/drivers/idotmatrix/assets/images/xlarge.png"
      },
      "settings": [
        {
          "type": "group",
          "label": { "en": "Display", "de": "Anzeige", "nl": "Display" },
          "children": [
            {
              "id": "pixel_size",
              "type": "dropdown",
              "label": { "en": "Pixel size", "de": "Pixel-Größe", "nl": "Pixelgrootte" },
              "value": "32",
              "values": [
                { "id": "16", "label": { "en": "16x16", "de": "16x16", "nl": "16x16" } },
                { "id": "32", "label": { "en": "32x32", "de": "32x32", "nl": "32x32" } },
                { "id": "64", "label": { "en": "64x64", "de": "64x64", "nl": "64x64" } }
              ]
            },
            {
              "id": "flip",
              "type": "checkbox",
              "label": { "en": "Rotate 180°", "de": "180° gedreht", "nl": "180° draaien" },
              "value": false
            }
          ]
        },
        {
          "type": "group",
          "label": { "en": "Remote media server", "de": "Externer Media-Server", "nl": "Externe media-server" },
          "children": [
            {
              "id": "media_base_url",
              "type": "text",
              "label": { "en": "Base URL", "de": "Basis-URL", "nl": "Basis-URL" },
              "value": "",
              "hint": {
                "en": "URL of a directory listing on your LAN (e.g. http://192.168.178.42:8080/idotmatrix/). Works with nginx autoindex, Apache, Python http.server, or any server that returns an HTML listing or an index.json.",
                "de": "URL eines Verzeichnis-Listings im LAN (z.B. http://192.168.178.42:8080/idotmatrix/). Funktioniert mit nginx autoindex, Apache, Python http.server oder jedem Server, der ein HTML-Listing oder eine index.json liefert.",
                "nl": "URL van een directory-listing op je LAN (bijv. http://192.168.178.42:8080/idotmatrix/). Werkt met nginx autoindex, Apache, Python http.server, of elke server die een HTML-listing of index.json teruggeeft."
              }
            }
          ]
        },
        {
          "type": "group",
          "label": { "en": "Diagnostics", "de": "Diagnose", "nl": "Diagnose" },
          "children": [
            {
              "id": "last_rssi",
              "type": "text",
              "label": { "en": "Last RSSI", "de": "Letzter RSSI", "nl": "Laatste RSSI" },
              "value": "",
              "hint": {
                "en": "Signal strength sampled periodically (lower numbers are weaker, e.g. -85 dBm = far away).",
                "de": "Signalstärke wird periodisch gemessen (niedrigere Zahlen = schwächer, z.B. -85 dBm = weit weg).",
                "nl": "Signaalsterkte wordt periodiek gemeten (lagere getallen = zwakker, bv. -85 dBm = ver weg)."
              }
            },
            {
              "id": "probe_result",
              "type": "textarea",
              "label": { "en": "Last probe result", "de": "Letztes Probe-Ergebnis", "nl": "Laatste probe-resultaat" },
              "value": "",
              "hint": {
                "en": "Read-only JSON of the most recent capability probe.",
                "de": "Nur-Lese-JSON des letzten Capability-Probe-Laufs.",
                "nl": "Alleen-lezen JSON van de laatste capability-probe."
              }
            }
          ]
        }
      ]
    }
  ],
  "flow": {
    "triggers": [
      {
        "id": "device_connected",
        "title": {
          "en": "Display connected",
          "de": "Display verbunden",
          "nl": "Display verbonden"
        },
        "args": [
          { "name": "device", "type": "device", "filter": "driver_id=idotmatrix" }
        ]
      },
      {
        "id": "device_disconnected",
        "title": {
          "en": "Display disconnected",
          "de": "Display getrennt",
          "nl": "Display losgekoppeld"
        },
        "args": [
          { "name": "device", "type": "device", "filter": "driver_id=idotmatrix" }
        ]
      }
    ],
    "conditions": [
      {
        "id": "is_connected",
        "title": {
          "en": "Display !{{is|isn't}} connected",
          "de": "Display !{{ist|ist nicht}} verbunden",
          "nl": "Display !{{is|is niet}} verbonden"
        },
        "titleFormatted": {
          "en": "Display !{{is|isn't}} connected",
          "de": "Display !{{ist|ist nicht}} verbunden",
          "nl": "Display !{{is|is niet}} verbonden"
        },
        "args": [
          { "name": "device", "type": "device", "filter": "driver_id=idotmatrix" }
        ]
      },
      {
        "id": "brightness_above",
        "title": {
          "en": "Brightness !{{is|isn't}} above",
          "de": "Helligkeit !{{ist|ist nicht}} über",
          "nl": "Helderheid !{{is|is niet}} boven"
        },
        "titleFormatted": {
          "en": "Brightness !{{is|isn't}} above [[percent]]%",
          "de": "Helligkeit !{{ist|ist nicht}} über [[percent]]%",
          "nl": "Helderheid !{{is|is niet}} boven [[percent]]%"
        },
        "args": [
          { "name": "device", "type": "device", "filter": "driver_id=idotmatrix" },
          {
            "name": "percent",
            "type": "number",
            "title": { "en": "Percent", "de": "Prozent", "nl": "Percentage" },
            "min": 0, "max": 100, "step": 1
          }
        ]
      }
    ],
    "actions": [
      {
        "id": "show_text",
        "title": { "en": "Show text", "de": "Text anzeigen", "nl": "Tekst tonen" },
        "titleFormatted": {
          "en": "Show text [[text]] in [[color]] mode [[mode]] speed [[speed]] mirror [[mirror]]",
          "de": "Text [[text]] in [[color]] Modus [[mode]] Geschwindigkeit [[speed]] gespiegelt [[mirror]] anzeigen",
          "nl": "Toon tekst [[text]] in [[color]] modus [[mode]] snelheid [[speed]] gespiegeld [[mirror]]"
        },
        "args": [
          { "name": "device", "type": "device", "filter": "driver_id=idotmatrix" },
          { "name": "text", "type": "text", "title": { "en": "Text", "de": "Text", "nl": "Tekst" } },
          { "name": "color", "type": "color", "title": { "en": "Color", "de": "Farbe", "nl": "Kleur" } },
          {
            "name": "mode", "type": "dropdown",
            "title": { "en": "Mode", "de": "Modus", "nl": "Modus" },
            "values": [
              { "id": "0", "label": { "en": "Replace", "de": "Ersetzen", "nl": "Vervangen" } },
              { "id": "1", "label": { "en": "Marquee", "de": "Laufschrift", "nl": "Lopende tekst" } },
              { "id": "2", "label": { "en": "Reverse marquee", "de": "Laufschrift rückwärts", "nl": "Lopende tekst omgekeerd" } },
              { "id": "3", "label": { "en": "Rise", "de": "Aufsteigend", "nl": "Stijgend" } },
              { "id": "4", "label": { "en": "Lower", "de": "Absteigend", "nl": "Dalend" } },
              { "id": "5", "label": { "en": "Blink", "de": "Blinken", "nl": "Knipperen" } },
              { "id": "6", "label": { "en": "Fade", "de": "Überblenden", "nl": "Vervagen" } },
              { "id": "7", "label": { "en": "Tetris", "de": "Tetris", "nl": "Tetris" } },
              { "id": "8", "label": { "en": "Fill", "de": "Füllen", "nl": "Vullen" } }
            ]
          },
          {
            "name": "speed", "type": "range",
            "title": { "en": "Speed", "de": "Geschwindigkeit", "nl": "Snelheid" },
            "min": 1, "max": 100, "step": 1, "value": 95
          },
          {
            "name": "mirror", "type": "checkbox",
            "title": { "en": "Mirror (for camera reflection)", "de": "Spiegeln (für Kamera-Reflexion)", "nl": "Spiegelen (voor camera-reflectie)" },
            "value": false
          }
        ]
      },
      {
        "id": "show_sensor_value",
        "title": {
          "en": "Show sensor value",
          "de": "Sensor-Wert anzeigen",
          "nl": "Sensorwaarde tonen"
        },
        "titleFormatted": {
          "en": "Show [[label]] [[value]] [[unit]] ([[decimals]] dec) at [[speed]] in [[color]] mirror [[mirror]]",
          "de": "[[label]] [[value]] [[unit]] ([[decimals]] Dez.) bei [[speed]] in [[color]] gespiegelt [[mirror]] anzeigen",
          "nl": "Toon [[label]] [[value]] [[unit]] ([[decimals]] dec) op [[speed]] in [[color]] gespiegeld [[mirror]]"
        },
        "hint": {
          "en": "Show a numeric value with a label and a unit (e.g. \"Temp 21 °C\"). Wire any Homey sensor or insight token to the value field.",
          "de": "Zeigt einen Zahlenwert mit Label und Einheit an (z.B. \"Temp 21 °C\"). Verbinde einen beliebigen Sensor- oder Insight-Token mit dem Wert-Feld.",
          "nl": "Toont een getalswaarde met label en eenheid (bijv. \"Temp 21 °C\"). Koppel een Homey-sensortoken aan het waarde-veld."
        },
        "args": [
          { "name": "device", "type": "device", "filter": "driver_id=idotmatrix" },
          { "name": "label", "type": "text", "title": { "en": "Label", "de": "Bezeichnung", "nl": "Label" }, "placeholder": { "en": "e.g. Temp" } },
          { "name": "value", "type": "text", "title": { "en": "Value", "de": "Wert", "nl": "Waarde" } },
          { "name": "unit", "type": "text", "title": { "en": "Unit", "de": "Einheit", "nl": "Eenheid" }, "placeholder": { "en": "e.g. °C" } },
          { "name": "decimals", "type": "number", "title": { "en": "Decimals", "de": "Nachkommastellen", "nl": "Decimalen" }, "min": 0, "max": 4, "step": 1, "value": 1 },
          { "name": "color", "type": "color", "title": { "en": "Color", "de": "Farbe", "nl": "Kleur" } },
          { "name": "speed", "type": "range", "title": { "en": "Speed", "de": "Geschwindigkeit", "nl": "Snelheid" }, "min": 1, "max": 100, "step": 1, "value": 95 },
          {
            "name": "mirror", "type": "checkbox",
            "title": { "en": "Mirror (for camera reflection)", "de": "Spiegeln (für Kamera-Reflexion)", "nl": "Spiegelen (voor camera-reflectie)" },
            "value": false
          }
        ]
      },
      {
        "id": "show_notification",
        "title": {
          "en": "Show notification",
          "de": "Benachrichtigung anzeigen",
          "nl": "Notificatie tonen"
        },
        "titleFormatted": {
          "en": "Show notification [[message]] in [[color]] at speed [[speed]] mirror [[mirror]]",
          "de": "Benachrichtigung [[message]] in [[color]] bei Geschwindigkeit [[speed]] gespiegelt [[mirror]] anzeigen",
          "nl": "Toon notificatie [[message]] in [[color]] op snelheid [[speed]] gespiegeld [[mirror]]"
        },
        "args": [
          { "name": "device", "type": "device", "filter": "driver_id=idotmatrix" },
          { "name": "message", "type": "text", "title": { "en": "Message", "de": "Nachricht", "nl": "Bericht" } },
          { "name": "color", "type": "color", "title": { "en": "Color", "de": "Farbe", "nl": "Kleur" } },
          { "name": "speed", "type": "range", "title": { "en": "Speed", "de": "Geschwindigkeit", "nl": "Snelheid" }, "min": 1, "max": 100, "step": 1, "value": 80 },
          {
            "name": "mirror", "type": "checkbox",
            "title": { "en": "Mirror (for camera reflection)", "de": "Spiegeln (für Kamera-Reflexion)", "nl": "Spiegelen (voor camera-reflectie)" },
            "value": false
          }
        ]
      },
      {
        "id": "show_sticker",
        "title": {
          "en": "Show built-in sticker",
          "de": "Eingebauten Sticker anzeigen",
          "nl": "Ingebouwde sticker tonen"
        },
        "titleFormatted": {
          "en": "Show sticker [[sticker]] (fit: [[fit]], bg: [[background]])",
          "de": "Sticker [[sticker]] anzeigen (Fit: [[fit]], BG: [[background]])",
          "nl": "Toon sticker [[sticker]] (fit: [[fit]], achtergrond: [[background]])"
        },
        "args": [
          { "name": "device", "type": "device", "filter": "driver_id=idotmatrix" },
          { "name": "sticker", "type": "autocomplete", "title": { "en": "Sticker", "de": "Sticker", "nl": "Sticker" }, "placeholder": { "en": "heart, fire, smile…" } },
          {
            "name": "fit", "type": "dropdown", "title": { "en": "Fit", "de": "Anpassung", "nl": "Passing" },
            "values": [
              { "id": "center", "label": { "en": "Center (no resize)", "de": "Zentriert (keine Skalierung)", "nl": "Gecentreerd" } },
              { "id": "contain", "label": { "en": "Contain (letterbox)", "de": "Einpassen (Letterbox)", "nl": "Passend (letterbox)" } },
              { "id": "cover", "label": { "en": "Cover (crop)", "de": "Füllen (zuschneiden)", "nl": "Vullen (bijsnijden)" } },
              { "id": "stretch", "label": { "en": "Stretch", "de": "Strecken", "nl": "Uitrekken" } }
            ]
          },
          { "name": "background", "type": "color", "title": { "en": "Background", "de": "Hintergrund", "nl": "Achtergrond" } }
        ]
      },
      {
        "id": "show_remote_image",
        "title": {
          "en": "Show image from remote server",
          "de": "Bild vom externen Server anzeigen",
          "nl": "Toon afbeelding van externe server"
        },
        "titleFormatted": {
          "en": "Show image [[file]] from remote server (fit: [[fit]], bg: [[background]], dither: [[dither]])",
          "de": "Bild [[file]] vom externen Server anzeigen (Fit: [[fit]], BG: [[background]], Dither: [[dither]])",
          "nl": "Toon afbeelding [[file]] van externe server (fit: [[fit]], achtergrond: [[background]], dither: [[dither]])"
        },
        "hint": {
          "en": "Lists images from the URL configured under device settings → Remote media server. Works with any HTTP directory listing (nginx autoindex, Apache, python -m http.server) or an index.json. Auto-converts and resizes any source format to the display.",
          "de": "Listet Bilder von der unter Geräteeinstellungen → Externer Media-Server konfigurierten URL. Funktioniert mit jedem HTTP-Verzeichnis-Listing (nginx autoindex, Apache, python -m http.server) oder einer index.json. Konvertiert und skaliert jedes Quellformat automatisch auf die Display-Auflösung.",
          "nl": "Toont afbeeldingen van de URL die is ingesteld onder apparaatinstellingen → Externe media-server. Werkt met elke HTTP directory listing (nginx autoindex, Apache, python -m http.server) of een index.json. Converteert en schaalt elk bronformaat automatisch naar de display-resolutie."
        },
        "args": [
          { "name": "device", "type": "device", "filter": "driver_id=idotmatrix" },
          { "name": "file", "type": "autocomplete", "title": { "en": "File", "de": "Datei", "nl": "Bestand" }, "placeholder": { "en": "Type to filter…" } },
          {
            "name": "fit", "type": "dropdown", "title": { "en": "Fit", "de": "Anpassung", "nl": "Passing" },
            "values": [
              { "id": "contain", "label": { "en": "Contain (letterbox)", "de": "Einpassen (Letterbox)", "nl": "Passend" } },
              { "id": "cover", "label": { "en": "Cover (crop)", "de": "Füllen (zuschneiden)", "nl": "Vullen" } },
              { "id": "stretch", "label": { "en": "Stretch", "de": "Strecken", "nl": "Uitrekken" } },
              { "id": "center", "label": { "en": "Center (no resize)", "de": "Zentriert", "nl": "Gecentreerd" } }
            ]
          },
          { "name": "background", "type": "color", "title": { "en": "Background", "de": "Hintergrund", "nl": "Achtergrond" } },
          { "name": "dither", "type": "checkbox", "title": { "en": "Dither (better for photos)", "de": "Dithering (besser für Fotos)", "nl": "Dithering (beter voor foto's)" }, "value": false }
        ]
      },
      {
        "id": "show_stored_image",
        "title": {
          "en": "Show stored image",
          "de": "Gespeichertes Bild anzeigen",
          "nl": "Toon opgeslagen afbeelding"
        },
        "titleFormatted": {
          "en": "Show stored image [[file]] (fit: [[fit]], bg: [[background]], dither: [[dither]])",
          "de": "Gespeichertes Bild [[file]] anzeigen (Fit: [[fit]], BG: [[background]], Dither: [[dither]])",
          "nl": "Toon opgeslagen afbeelding [[file]] (fit: [[fit]], achtergrond: [[background]], dither: [[dither]])"
        },
        "hint": {
          "en": "Pick from images uploaded to this app's local media store. Upload via: POST http://<homey-ip>/api/app/com.idotmatrix/media/<filename>.",
          "de": "Wähle aus Bildern im lokalen Media-Store dieser App. Upload via: POST http://<homey-ip>/api/app/com.idotmatrix/media/<dateiname>.",
          "nl": "Kies uit afbeeldingen in de lokale media-store. Upload via: POST http://<homey-ip>/api/app/com.idotmatrix/media/<bestandsnaam>."
        },
        "args": [
          { "name": "device", "type": "device", "filter": "driver_id=idotmatrix" },
          { "name": "file", "type": "autocomplete", "title": { "en": "File", "de": "Datei", "nl": "Bestand" }, "placeholder": { "en": "Type to filter…" } },
          {
            "name": "fit", "type": "dropdown", "title": { "en": "Fit", "de": "Anpassung", "nl": "Passing" },
            "values": [
              { "id": "contain", "label": { "en": "Contain (letterbox)", "de": "Einpassen (Letterbox)", "nl": "Passend" } },
              { "id": "cover", "label": { "en": "Cover (crop)", "de": "Füllen (zuschneiden)", "nl": "Vullen" } },
              { "id": "stretch", "label": { "en": "Stretch", "de": "Strecken", "nl": "Uitrekken" } },
              { "id": "center", "label": { "en": "Center (no resize)", "de": "Zentriert", "nl": "Gecentreerd" } }
            ]
          },
          { "name": "background", "type": "color", "title": { "en": "Background", "de": "Hintergrund", "nl": "Achtergrond" } },
          { "name": "dither", "type": "checkbox", "title": { "en": "Dither", "de": "Dithering", "nl": "Dithering" }, "value": false }
        ]
      },
      {
        "id": "show_image_url",
        "title": {
          "en": "Show image from URL",
          "de": "Bild von URL anzeigen",
          "nl": "Toon afbeelding van URL"
        },
        "titleFormatted": {
          "en": "Show image from [[url]] ([[kind]], fit: [[fit]], bg: [[background]], dither: [[dither]])",
          "de": "Bild von [[url]] anzeigen ([[kind]], Fit: [[fit]], BG: [[background]], Dither: [[dither]])",
          "nl": "Toon afbeelding van [[url]] ([[kind]], fit: [[fit]], achtergrond: [[background]], dither: [[dither]])"
        },
        "hint": {
          "en": "Fetches a PNG, JPG/JPEG, BMP, WEBP, or GIF from any HTTP/HTTPS URL and shows it on the display. Auto-converts and resizes to the display size; GIFs stay animated.",
          "de": "Lädt ein PNG, JPG/JPEG, BMP, WEBP oder GIF von einer URL und zeigt es auf dem Display. Konvertiert und skaliert automatisch; GIFs bleiben animiert.",
          "nl": "Haalt PNG, JPG/JPEG, BMP, WEBP of GIF op van een URL en toont het op het display. Converteert en schaalt automatisch; GIFs blijven geanimeerd."
        },
        "args": [
          { "name": "device", "type": "device", "filter": "driver_id=idotmatrix" },
          { "name": "url", "type": "text", "title": { "en": "Image URL", "de": "Bild-URL", "nl": "URL" }, "placeholder": { "en": "https://…/image.png" } },
          {
            "name": "kind", "type": "dropdown", "title": { "en": "Mode", "de": "Modus", "nl": "Modus" },
            "values": [
              { "id": "auto", "label": { "en": "Auto-detect", "de": "Auto", "nl": "Automatisch" } },
              { "id": "png", "label": { "en": "Force static (PNG/JPG)", "de": "Erzwinge statisch", "nl": "Forceer statisch" } },
              { "id": "gif", "label": { "en": "Force animated (GIF)", "de": "Erzwinge animiert", "nl": "Forceer geanimeerd" } }
            ]
          },
          {
            "name": "fit", "type": "dropdown", "title": { "en": "Fit", "de": "Anpassung", "nl": "Passing" },
            "values": [
              { "id": "contain", "label": { "en": "Contain (letterbox)", "de": "Einpassen (Letterbox)", "nl": "Passend" } },
